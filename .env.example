# ═══════════════════════════════════════════════
# Discussion Agent — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════

# ── Anthropic ──────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── LTI Credentials ────────────────────────────
# Choose any key/secret pair — must match exactly
# what you enter in Canvas when registering the tool.
LTI_KEY=discussion_agent_lti_key
LTI_SECRET=change_this_to_a_long_random_secret_string

# ── Default content (used if Canvas params are missing) ──
DEFAULT_QUESTION=What are the key tensions in this week's readings?
DEFAULT_ROLE=socratic

# ── Server ─────────────────────────────────────
PORT=3000
# On Vercel/Render/Railway this is set automatically
